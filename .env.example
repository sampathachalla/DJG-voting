VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

VITE_DEFAULT_TESTNET=sepolia

# JSON-RPC URL: must accept HTTP POST with a JSON-RPC body at this exact URL (ethers, Hardhat, and the backend use POST). Avoid URLs that return HTML for GET/POST.
# Public default (verified eth_chainId): https://ethereum-sepolia-rpc.publicnode.com — or use Infura/Alchemy/etc.
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
VITE_SEPOLIA_VOTING_CONTRACT_ADDRESS=0xYourSepoliaVotingFactoryAddress
VITE_SEPOLIA_BLOCK_EXPLORER_BASE_URL=https://sepolia.etherscan.io

VITE_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
VITE_AMOY_VOTING_CONTRACT_ADDRESS=0xYourAmoyVotingFactoryAddress
VITE_AMOY_BLOCK_EXPLORER_BASE_URL=https://amoy.polygonscan.com

# Legacy fallback used by older frontend code paths. Keep this aligned with Sepolia if needed.
VITE_VOTING_CONTRACT_ADDRESS=0xYourSepoliaVotingFactoryAddress
VITE_BLOCK_EXPLORER_BASE_URL=https://sepolia.etherscan.io
# Private voting API base URL (must include /api — Express mounts private routes at /api).
# Leave unset for local dev: the app defaults to same-origin /api and Vite proxies to http://127.0.0.1:8081 (see vite.config.ts).
# For production when the API is on another host, set the full URL, e.g. https://api.example.com/api
# VITE_PRIVATE_VOTING_API_URL=

# Optional: Etherscan v2 unified API key (https://etherscan.io/myapikey).
# When set, the in-app wallet rail loads recent on-chain transactions for the
# connected address. Without a key the rail still works and offers a deep link
# to the explorer's address page instead.
VITE_ETHERSCAN_API_KEY=
# Optional per-network overrides (take precedence over VITE_ETHERSCAN_API_KEY).
VITE_SEPOLIA_ETHERSCAN_API_KEY=
VITE_AMOY_ETHERSCAN_API_KEY=

DEPLOYER_PRIVATE_KEY=0xyourtestnetprivatekey
