PORT=8081
# Comma-separated extra origins (production, tunnel URLs, etc.). Any http(s) origin with host
# localhost or 127.0.0.1 is always allowed on any port for local development.
BACKEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# JSON-RPC URL: must accept HTTP POST with a JSON-RPC body at this URL. Public default: https://ethereum-sepolia-rpc.publicnode.com (or Infura, Alchemy, etc.).
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
BACKEND_RELAYER_PRIVATE_KEY=0x...

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
